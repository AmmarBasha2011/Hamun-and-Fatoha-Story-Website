<%- include('layout_head', { title: "همون وفتوها - السجل المظلم" }) %>

<div style="text-align: center; padding: 4rem 1rem;">
    <h1 style="font-family: 'Amiri', serif; font-size: 3.5rem; color: var(--text-gold); margin-bottom: 1rem; text-shadow: 0 0 20px var(--accent-glow);">همون وفتوها</h1>
    <p style="font-size: 1.1rem; color: var(--text-silver); max-width: 600px; margin: 0 auto 1.5rem; line-height: 1.6; opacity: 0.8;">سجل السلالات المفقودة في أعماق المجرة العَمّارية</p>
    
    <!-- Resume Reading Widget -->
    <div id="resumeWidget" style="display: none; margin-bottom: 3rem;">
        <div style="background: rgba(212, 175, 55, 0.1); border: 1px dashed var(--text-gold); padding: 1.5rem; display: inline-block; border-radius: 12px;">
            <p style="color: var(--text-silver); margin-bottom: 1rem; font-size: 0.9rem;">هل تود إكمال القراءة من حيث توقفت؟</p>
            <a id="resumeLink" href="#" class="btn-ritual" style="padding: 0.5rem 1.5rem; font-size: 1rem;">استكمال القراءة</a>
        </div>
    </div>

    <script>
        const s1Progress = localStorage.getItem('progress_s1');
        const s2Progress = localStorage.getItem('progress_s2');
        const resumeWidget = document.getElementById('resumeWidget');
        const resumeLink = document.getElementById('resumeLink');

        if (s2Progress) {
            resumeWidget.style.display = 'block';
            resumeLink.href = `/season/2/episode/${s2Progress}`;
            resumeLink.innerText = `استكمال الموسم الثاني - جزء ${s2Progress}`;
        } else if (s1Progress) {
            resumeWidget.style.display = 'block';
            resumeLink.href = `/season/1/episode/${s1Progress}`;
            resumeLink.innerText = `استكمال الموسم الأول - جزء ${s1Progress}`;
        }
    </script>
    
    <% if (seasons && seasons.length > 0) { %>
        <div class="season-portal" style="display: flex; flex-direction: column; gap: 2rem; align-items: center; padding: 0 1rem;">
            <% seasons.forEach(season => { %>
                <div class="season-card-v35" style="width: 100%; max-width: 400px; background: var(--bg-tablet); border-radius: 12px; overflow: hidden; border: 1px solid <%= season.id == 2 ? '#00f2ff' : 'var(--text-gold)' %>; box-shadow: var(--shadow-deep); transition: var(--t-ritual);">
                    <div class="cover-container" style="position: relative; height: 250px; overflow: hidden;">
                        <img src="<%= season.cover %>" alt="<%= season.name %>" style="width: 100%; height: 100%; object-fit: cover; transition: 0.5s;">
                        <div style="position: absolute; inset: 0; background: linear-gradient(to top, var(--bg-tablet), transparent);"></div>
                        <div style="position: absolute; bottom: 15px; right: 20px;">
                            <span style="background: <%= season.id == 2 ? '#00f2ff' : 'var(--text-gold)' %>; color: #000; padding: 4px 12px; border-radius: 20px; font-weight: bold; font-size: 0.8rem;">
                                <%= season.count %> جزء
                            </span>
                        </div>
                    </div>
                    <div style="padding: 1.5rem; text-align: right;">
                        <h2 style="font-family: 'Amiri', serif; color: <%= season.id == 2 ? '#00f2ff' : 'var(--text-gold)' %>; font-size: 1.6rem; margin-bottom: 0.5rem;"><%= season.name %></h2>
                        <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; line-height: 1.4;">
                            <%= season.id == 2 ? 'طوفان السُّبات العظيم يهدد بقاء المجرة.' : 'رحلة البحث عن الميثاق وبداية الصراع الأزلي.' %>
                        </p>
                        <a href="/season/<%= season.id %>/episode/1" class="btn-ritual" style="display: block; width: 100%; text-align: center; border-radius: 8px; border-color: <%= season.id == 2 ? '#00f2ff' : 'var(--text-gold)' %>; color: <%= season.id == 2 ? '#00f2ff' : 'var(--text-gold)' %>;">بدء القراءة</a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 4rem; padding: 6rem 2rem; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; border-bottom: 1px solid var(--border-runic); padding-bottom: 2rem;">
        <h3 style="font-family: 'Amiri', serif; color: var(--text-gold); font-size: 1.8rem; margin-bottom: 1rem;">أرشيف أبدي</h3>
        <p style="color: var(--text-muted);">كلماتٌ لا تُمحى، سُطرت في قلب الفراغ لتشهد على عظمة السلالات.</p>
    </div>
    <div style="text-align: center; border-bottom: 1px solid var(--border-runic); padding-bottom: 2rem;">
        <h3 style="font-family: 'Amiri', serif; color: var(--text-gold); font-size: 1.8rem; margin-bottom: 1rem;">لغة النجوم</h3>
        <p style="color: var(--text-muted);">نظام مسرد ذكي يفك شفرات التاريخ بلمسة واحدة.</p>
    </div>
    <div style="text-align: center; border-bottom: 1px solid var(--border-runic); padding-bottom: 2rem;">
        <h3 style="font-family: 'Amiri', serif; color: var(--text-gold); font-size: 1.8rem; margin-bottom: 1rem;">تركيز مطلق</h3>
        <p style="color: var(--text-muted);">تصميم يقدس القراءة ويمنحك السكينة في حضرة الكلمات.</p>
    </div>
</div>

<%- include('layout_foot') %>
