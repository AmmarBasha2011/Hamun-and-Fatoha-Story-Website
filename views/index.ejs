<%- include('layout_head', { title: "همون وفتوها - السجل المظلم" }) %>

<div class="v7-container" style="text-align: center; padding: 4rem 1rem;">
    <h1 style="font-size: 4rem; margin-bottom: 1rem;">ملحمة همون وفتوها</h1>
    <p class="cairo" style="font-size: 1.2rem; color: var(--text-secondary); max-width: 700px; margin: 0 auto 2rem; line-height: 1.6;">بوابة السلالات المفقودة في أعماق المجرّة العَمّارية - الإصدار السابع</p>
    
    <!-- Resume Reading Widget -->
    <div id="resumeWidget" style="display: none; margin-bottom: 4rem;">
        <div class="glass-card" style="display: inline-block; padding: 2rem;">
            <p class="cairo" style="color: var(--text-primary); margin-bottom: 1.5rem;">أهلاً بك مجدداً أيها المسافر. هل تود العودة لآخر نقطة؟</p>
            <a id="resumeLink" href="#" class="btn-v7" style="padding: 1rem 2.5rem;">استئناف الرحلة</a>
        </div>
    </div>

    <script>
        const s1Progress = localStorage.getItem('progress_s1');
        const s2Progress = localStorage.getItem('progress_s2');
        const resumeWidget = document.getElementById('resumeWidget');
        const resumeLink = document.getElementById('resumeLink');

        if (s2Progress) {
            resumeWidget.style.display = 'block';
            resumeLink.href = `/season/2/episode/${s2Progress}`;
            resumeLink.innerText = `استكمال الموسم الثاني - جزء ${s2Progress}`;
        } else if (s1Progress) {
            resumeWidget.style.display = 'block';
            resumeLink.href = `/season/1/episode/${s1Progress}`;
            resumeLink.innerText = `استكمال الموسم الأول - جزء ${s1Progress}`;
        }
    </script>
    
    <% if (seasons && seasons.length > 0) { %>
        <div class="mobile-first-grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));">
            <% seasons.forEach(season => { %>
                <div class="glass-card" style="padding: 0; overflow: hidden; border-color: <%= season.id == 2 ? 'var(--accent-neon)' : 'var(--accent-gold)' %>;">
                    <div style="position: relative; height: 200px;">
                        <img src="<%= season.cover %>" alt="<%= season.name %>" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.6;">
                        <div style="position: absolute; inset: 0; background: linear-gradient(transparent, var(--bg-main));"></div>
                        <div style="position: absolute; bottom: 10px; right: 20px;">
                            <span class="cairo" style="background: <%= season.id == 2 ? 'var(--accent-neon)' : 'var(--accent-gold)' %>; color: #000; padding: 2px 15px; border-radius: 20px; font-weight: bold; font-size: 0.8rem;">
                                <%= season.count %> جزء
                            </span>
                        </div>
                    </div>
                    <div style="padding: 2rem; text-align: right;">
                        <h2 style="color: <%= season.id == 2 ? 'var(--accent-neon)' : 'var(--accent-gold)' %>; margin-bottom: 1rem;"><%= season.name %></h2>
                        <p class="cairo" style="color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 2rem;">
                            <%= season.id == 2 ? 'طوفان السُّبات العظيم يهدد بقاء المجرة.' : 'رحلة البحث عن الميثاق وبداية الصراع الأزلي.' %>
                        </p>
                        <a href="/season/<%= season.id %>" class="btn-v7" style="display: block; border-color: <%= season.id == 2 ? 'var(--accent-neon)' : 'var(--accent-gold)' %>; color: <%= season.id == 2 ? 'var(--accent-neon)' : 'var(--accent-gold)' %>;">دخول السجل</a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<div class="v7-container mobile-first-grid" style="padding: 8rem 1rem; border-top: 1px solid var(--border-glass);">
    <div style="text-align: center;">
        <h3 style="font-size: 2rem; margin-bottom: 1rem;">🌌 أرشيف أبدي</h3>
        <p class="cairo" style="color: var(--text-secondary);">كلماتٌ لا تُمحى، سُطرت في قلب الفراغ لتشهد على عظمة السلالات.</p>
    </div>
    <div style="text-align: center;">
        <h3 style="font-size: 2rem; margin-bottom: 1rem;">🧠 لغة النجوم</h3>
        <p class="cairo" style="color: var(--text-secondary);">نظام مسرد ذكي يفك شفرات التاريخ بلمسة واحدة.</p>
    </div>
    <div style="text-align: center;">
        <h3 style="font-size: 2rem; margin-bottom: 1rem;">✨ تركيز مطلق</h3>
        <p class="cairo" style="color: var(--text-secondary);">تصميم يقدس القراءة ويمنحك السكينة في حضرة الكلمات.</p>
    </div>
</div>

<%- include('layout_foot') %>
