<%- include('layout_head', { title: "إعدادات المجرّة - V7" }) %>

<div class="v7-container v7-animate-entry" style="padding-bottom: 5rem;">
    <header style="text-align: center; margin: 3rem 0;">
        <h1>إعدادات التجربة</h1>
        <p class="cairo" style="color: var(--text-secondary);">خصص رحلتك عبر النجوم</p>
    </header>

    <div class="mobile-first-grid">
        <!-- Feature 1: Progress Dashboard -->
        <section class="glass-card">
            <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">📊 سجل القراءة</h2>
            <div id="v7-progress-stats" class="cairo">
                <p>الموسم الأول: <span id="s1-perc">0%</span></p>
                <div style="background: rgba(255,255,255,0.1); height: 8px; border-radius: 4px; margin: 10px 0;">
                    <div id="s1-bar" style="height: 100%; width: 0; background: var(--accent-gold); border-radius: 4px;"></div>
                </div>
                <p>الموسم الثاني: <span id="s2-perc">0%</span></p>
                <div style="background: rgba(255,255,255,0.1); height: 8px; border-radius: 4px; margin: 10px 0;">
                    <div id="s2-bar" style="height: 100%; width: 0; background: var(--accent-neon); border-radius: 4px;"></div>
                </div>
            </div>
        </section>

        <!-- Feature 5: Sound Mixer -->
        <section class="glass-card">
            <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">🎵 مازج الأصوات</h2>
            <div class="cairo">
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; margin-bottom: 0.5rem;">صوت الخلفية (البيئة)</label>
                    <input type="range" min="0" max="1" step="0.1" id="ambient-vol-range" style="width: 100%;">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem;">صوت القصة (الموسيقى)</label>
                    <input type="range" min="0" max="1" step="0.1" id="episode-vol-range" style="width: 100%;">
                </div>
            </div>
        </section>

        <!-- Theme & Notifications -->
        <section class="glass-card">
            <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">🎨 المظهر والتنبيهات</h2>
            <div class="cairo" style="display: flex; flex-direction: column; gap: 1rem;">
                <select id="v7-theme-select" class="btn-v7" style="width: 100%; background: var(--bg-main);">
                    <option value="ancient">مظهر Obsidian Ancient</option>
                    <option value="neon">مظهر Cosmic Neon</option>
                    <option value="solar">مظهر Solar Flare</option>
                    <option value="void">مظهر Eternal Void</option>
                </select>
                <button class="btn-v7" onclick="requestV7Notifications()">تفعيل التنبيهات اليومية</button>
                <button class="btn-v7" id="v7-focus-toggle">تبديل وضع التركيز (Focus Mode)</button>
            </div>
        </section>

        <!-- Feature 10: Offline Manager -->
        <section class="glass-card">
            <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">💾 التخزين والمزامنة</h2>
            <div class="cairo">
                <p style="font-size: 0.9rem; margin-bottom: 1rem;">إدارة المحتوى المتاح بدون اتصال</p>
                <button class="btn-v7" style="width: 100%;" onclick="caches.delete('v7-ammari-nexus-cache').then(() => alert('تم مسح التخزين المؤقت'))">مسح سجل التخزين</button>
                <div style="margin-top: 1rem; border-top: 1px solid var(--border-glass); padding-top: 1rem;">
                    <a href="/timeline" class="btn-v7" style="width: 100%;">📅 عرض الخط الزمني للمجرّة</a>
                </div>
            </div>
        </section>
    </div>
</div>

<script>
    // Initialize Progress
    const s1Prog = localStorage.getItem('progress_s1') || 0;
    const s2Prog = localStorage.getItem('progress_s2') || 0;
    const s1Perc = Math.round((s1Prog / 50) * 100);
    const s2Perc = Math.round((s2Prog / 30) * 100);

    document.getElementById('s1-perc').innerText = s1Perc + '%';
    document.getElementById('s1-bar').style.width = s1Perc + '%';
    document.getElementById('s2-perc').innerText = s2Perc + '%';
    document.getElementById('s2-bar').style.width = s2Perc + '%';

    // Initialize Audio Sliders
    const ambRange = document.getElementById('ambient-vol-range');
    const epRange = document.getElementById('episode-vol-range');
    ambRange.value = localStorage.getItem('v7_ambient_vol') || 0.3;
    epRange.value = localStorage.getItem('v7_episode_vol') || 0.6;

    ambRange.addEventListener('input', (e) => window.v7SetVolume('ambient', e.target.value));
    epRange.addEventListener('input', (e) => window.v7SetVolume('episode', e.target.value));

    // Theme Selector
    const themeSelect = document.getElementById('v7-theme-select');
    themeSelect.value = localStorage.getItem('v7_theme') || 'ancient';
    themeSelect.addEventListener('change', (e) => {
        document.documentElement.className = '';
        if(e.target.value !== 'ancient') document.documentElement.classList.add('theme-' + e.target.value);
        localStorage.setItem('v7_theme', e.target.value);
    });

    // Feature 2: Focus Mode Toggle
    document.getElementById('v7-focus-toggle').addEventListener('click', () => {
        const isFocus = document.body.classList.toggle('v7-focus-mode');
        localStorage.setItem('v7_focus_mode', isFocus);
        alert(isFocus ? 'تم تفعيل وضع التركيز. سيتم إخفاء العناصر المشتتة في القارئ.' : 'تم إيقاف وضع التركيز.');
    });
</script>

<%- include('layout_foot') %>
